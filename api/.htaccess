# PHP アップロード上限（音声文字起こし用）
# CGI/FastCGI では php_value が使えないため .user.ini で設定
<IfModule mod_php.c>
  php_value upload_max_filesize 55M
  php_value post_max_size 60M
  php_value max_execution_time 300
  php_value memory_limit 256M
</IfModule>

<Files ".env">
  Require all denied
</Files>
<Files ".user.ini">
  Require all denied
</Files>
<Files "*.json">
  Require all denied
</Files>
<Files "debug.log">
  Require all denied
</Files>
